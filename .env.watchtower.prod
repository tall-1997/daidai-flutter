# 呆呆面板生产版 Watchtower 配置
# 使用前请至少把 PUSHPLUS_TOKEN 改成你自己的 token。

# 呆呆面板镜像。切到 Debian 版可改为：
# docker.1ms.run/linzixuanzz/daidai-panel:debian
DAIDAI_PANEL_IMAGE=docker.1ms.run/linzixuanzz/daidai-panel:latest

# 容器和端口
DAIDAI_PANEL_CONTAINER_NAME=daidai-panel
WATCHTOWER_CONTAINER_NAME=daidai-watchtower
PANEL_HTTP_PORT=5700

# 面板数据目录
PANEL_DATA_DIR=./Dumb-Panel

# 时区
PANEL_TZ=Asia/Shanghai
WATCHTOWER_TZ=Asia/Shanghai

# 夜间维护窗口：每天 04:00 检查并执行更新
# 6 段 Cron：秒 分 时 日 月 星期
WATCHTOWER_SCHEDULE=0 0 4 * * *

# 单个容器优雅停止等待时间
WATCHTOWER_TIMEOUT=30s

# 通知级别：panic / fatal / error / warn / info / debug / trace
WATCHTOWER_NOTIFICATIONS_LEVEL=info

# 通知标题前缀和主机名
WATCHTOWER_NOTIFICATION_TITLE_TAG=[Daidai Panel]
WATCHTOWER_NOTIFICATIONS_HOSTNAME=daidai-prod

# Watchtower HTTP API：用于后台手动触发“立即检查更新”
WATCHTOWER_HTTP_API_TOKEN=REPLACE_WITH_WATCHTOWER_API_TOKEN
WATCHTOWER_HTTP_API_URL=http://daidai-watchtower:8080

# Push Plus token：请改成你自己的
PUSHPLUS_TOKEN=REPLACE_WITH_YOUR_PUSHPLUS_TOKEN

# 通过 Shoutrrr Generic Webhook 接入 Push Plus
WATCHTOWER_NOTIFICATION_URL=generic://www.pushplus.plus/send?template=json&titlekey=title&messagekey=content&$token=${PUSHPLUS_TOKEN}&$template=html
